<template>
  <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800/60 rounded-2xl p-5 shadow-xs flex flex-col justify-between h-35 transition-all duration-300 relative overflow-hidden">
    
    <div class="flex items-center justify-between shrink-0">
      <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider truncate max-w-[80%]">
        {{ title }}
      </span>
      <div :class="[
        'w-8 h-8 rounded-xl flex items-center justify-center border transition-colors',
        isPositive 
          ? 'bg-teal-50/60 dark:bg-teal-950/20 border-teal-100/70 dark:border-teal-900/40 text-teal-600 dark:text-teal-400' 
          : 'bg-rose-50/60 dark:bg-rose-950/20 border-rose-100/70 dark:border-rose-900/40 text-rose-600 dark:text-rose-400'
      ]">
        <i :class="['pi', icon, 'text-xs']"></i>
      </div>
    </div>

    <div class="my-2 min-w-0">
      <h2 class="text-xl sm:text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight truncate">
        {{ formattedValue }}
      </h2>
    </div>

    <div class="flex items-center gap-1.5 text-[11px] font-semibold shrink-0">
      <span :class="[
        'flex items-center gap-0.5 px-1.5 py-0.5 rounded-lg border',
        isPositive 
          ? 'bg-teal-500/10 border-teal-500/20 text-teal-600 dark:text-teal-400' 
          : 'bg-rose-500/10 border-rose-500/20 text-rose-600 dark:text-rose-400'
      ]">
        <i :class="['pi', isPositive ? 'pi-arrow-up-right' : 'pi-arrow-down-left', 'text-[9px]']"></i>
        {{ Math.abs(percentage) }}%
      </span>
      <span class="text-slate-400 dark:text-slate-500 font-medium">
        vs bulan lalu
      </span>
    </div>

  </div>
</template>

<script setup>
import { computed } from 'vue';

const props = defineProps({
  title: { type: String, default: 'KPI Title' },
  value: { type: [Number, String], default: 0 },
  percentage: { type: Number, default: 0 }, // Bisa positif (e.g., 12.5) atau negatif (e.g., -5.2)
  icon: { type: String, default: 'pi-chart-line' },
  isCurrency: { type: Boolean, default: false } // True jika format Rupiah
});

// Deteksi apakah tren bernilai positif (Grow Up) atau negatif (Grow Down)
const isPositive = computed(() => props.percentage >= 0);

// Format angka utama secara otomatis di tingkat komponen
const formattedValue = computed(() => {
  if (typeof props.value === 'string') return props.value;
  
  if (props.isCurrency) {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(props.props.value);
  }
  
  return props.value.toLocaleString('id-ID');
});
</script>